# ─────────────────────────────────────────────────────────────
#  Chat App — SINGLE shared environment template (repo root)
#  Copy to ".env" and fill in values:   cp .env.example .env
#  This is the ONLY .env in the repo. Used by BOTH layers:
#    • Backend  → backend/src/config/index.js (dotenv)
#    • Frontend → Vite `envDir` (repo root) in frontend/vite.config.js
#  Only VITE_*-prefixed vars are exposed to the browser bundle; the secrets
#  below stay server-side and are never shipped to the client.
#
#  Deploying on Render? You don't keep a .env there — set these as the service's
#  environment variables instead (render.yaml lists them). Render also injects
#  PORT and RENDER_EXTERNAL_URL automatically, so you can leave PORT/CLIENT_URL
#  unset in production. See DEPLOYMENT.md.
# ─────────────────────────────────────────────────────────────

# ══ BACKEND ══════════════════════════════════════════════════
# "development" | "production" | "test"
NODE_ENV=development
PORT=5001
# Allowed CORS / Socket.IO origin(s). Comma-separate to allow several.
#   dev:  http://localhost:5173
#   prod: https://your-app.onrender.com
# On Render this defaults to RENDER_EXTERNAL_URL when left unset.
CLIENT_URL=http://localhost:5173
# error | warn | info | debug
LOG_LEVEL=info
# Delete inactive anonymous guest accounts after this many days (MongoDB TTL).
GUEST_RETENTION_DAYS=30

# Local:  mongodb://localhost:27017/chat_app
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chat_app
MONGODB_URI=

# Long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# OPTIONAL — image & avatar uploads (https://cloudinary.com/console).
# Leave blank to run text-only: the server still boots and image upload is just
# disabled. Set all three to enable image sharing + avatar uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Clerk authentication — https://dashboard.clerk.com → API keys.
# CLERK_SECRET_KEY is optional (only used for Clerk Backend API calls).
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ══ FRONTEND (Vite — ONLY these VITE_* vars reach the browser) ═
# Dev-server port (read by vite.config.js + `npm run dev:free`). Not exposed to the client.
FRONTEND_PORT=5173

# "development" | "production"
VITE_APP_ENV=development
# REST API base (dev → backend; prod → "/api" since it's same-origin on Render).
VITE_API_URL=http://localhost:5001/api
# Socket.IO origin (dev → backend; prod → "/").
VITE_SOCKET_URL=http://localhost:5001

# Clerk publishable key for the browser (same pk_... as CLERK_PUBLISHABLE_KEY).
VITE_CLERK_PUBLISHABLE_KEY=

# ── WebRTC ICE servers (voice/video calls) ───────────────────
# STUN is free and always on (a Google/Cloudflare default list is used when
# VITE_STUN_URLS is blank). STUN alone is enough for calls between two devices on
# the SAME network.
#
# A TURN server RELAYS audio/video when a direct peer-to-peer path can't be formed
# — the usual case between two phones on mobile data, or behind strict/symmetric
# NATs. Without TURN such cross-network calls "connect" but no media flows.
#
# There is no longer a reliable no-signup public TURN relay (the old Metered
# "openrelayproject" credentials were retired). Easiest free option: ExpressTURN
# (https://www.expressturn.com — 1 TB/month free, static creds, no card). Sign up,
# copy your Username + Password into the two vars below, and the relay URLs default
# to ExpressTURN automatically. Set VITE_TURN_URL only to use your own relay
# (comma-separated URLs allowed); it shares the username/credential below.
VITE_STUN_URLS=
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
