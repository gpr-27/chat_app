# ─────────────────────────────────────────────────────────────
#  Chat App — SINGLE shared environment template (repo root)
#  Copy to ".env" and fill in values:   cp .env.example .env
#  This is the ONLY .env in the repo. Used by BOTH layers:
#    • Backend  → backend/src/config/index.js (dotenv)
#    • Frontend → Vite `envDir` (repo root) in frontend/vite.config.js
#  Only VITE_*-prefixed vars are exposed to the browser bundle; the secrets
#  below stay server-side and are never shipped to the client.
# ─────────────────────────────────────────────────────────────

# ══ BACKEND ══════════════════════════════════════════════════
# "development" | "production" | "test"
NODE_ENV=development
PORT=5001
# Allowed CORS / Socket.IO origin(s). Comma-separate to allow several.
#   dev:  http://localhost:5173
#   prod: https://your-app.example.com
CLIENT_URL=http://localhost:5173
# error | warn | info | debug
LOG_LEVEL=info
# Delete inactive anonymous guest accounts after this many days (MongoDB TTL).
GUEST_RETENTION_DAYS=30

# Local:  mongodb://localhost:27017/chat_app
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/chat_app
MONGODB_URI=

# Long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# From your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Clerk authentication — https://dashboard.clerk.com → API keys (both required).
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ══ FRONTEND (Vite — ONLY these VITE_* vars reach the browser) ═
# Dev-server port (read by vite.config.js + `npm run dev:free`). Not exposed to the client.
FRONTEND_PORT=5173

# "development" | "production"
VITE_APP_ENV=development
# REST API base (dev → backend; prod → "/api").
VITE_API_URL=http://localhost:5001/api
# Socket.IO origin (dev → backend; prod → "/").
VITE_SOCKET_URL=http://localhost:5001

# Clerk publishable key for the browser (same pk_... as CLERK_PUBLISHABLE_KEY).
VITE_CLERK_PUBLISHABLE_KEY=

# WebRTC ICE servers. Comma-separated STUN URLs (required); TURN optional.
VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=
